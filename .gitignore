data/raw/*
data/interim/*
data/processed/*
# exclude artifact CONTENTS (not the directory) so the negation below works —
# git cannot re-include a file whose parent directory is itself excluded
data/artifacts/*
# ship the small derived player-shares artifact (real StatsBomb-derived
# xG/xA shares, ~48 KB) so named scorers work without re-downloading events
!data/artifacts/player_shares.json
data/memory/
data/traces/
evals/out/
!data/**/.gitkeep
__pycache__/
*.pyc
.venv/
.env
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
