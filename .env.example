# Copy to .env (gitignored) and fill in. Never commit real keys.
# Both are optional — the system runs fully keyless, degrading gracefully.

# the-odds-api.com — 500 credits/month.
# Unlocks: upcoming fixtures + live odds for every league (incl. Liga MX, MLS),
# and switches the market-comparison / EV layer onto real prices.
ODDS_API_KEY=

# api-football.com — ~100 requests/day.
# Unlocks: CURRENT club squads (named scorers/assists on club league pages),
# confirmed lineups, and injuries for the availability features.
API_FOOTBALL_KEY=

# Optional: enables ReAct agent mode and the LLM-as-judge eval arm.
# ANTHROPIC_API_KEY=

# Gateway auth + rate limit (set a key for anything shared)
# GATEWAY_API_KEY=
# PREDICT_RATE_LIMIT=5/minute
